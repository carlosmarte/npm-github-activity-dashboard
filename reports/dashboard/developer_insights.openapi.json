{
  "openapi": "3.0.3",
  "info": {
    "title": "Developer Insights Report API",
    "description": "API specification for the developer insights report data structure generated by the CLI tool",
    "version": "1.0.0",
    "contact": {
      "name": "Developer Insights Tool",
      "url": "https://github.com/your-org/developer-insights"
    }
  },
  "paths": {},
  "components": {
    "schemas": {
      "DeveloperInsightsReport": {
        "type": "object",
        "required": ["metadata", "summary", "analytics"],
        "properties": {
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          },
          "summary": {
            "$ref": "#/components/schemas/Summary"
          },
          "analytics": {
            "$ref": "#/components/schemas/Analytics"
          },
          "rawData": {
            "$ref": "#/components/schemas/RawData"
          }
        }
      },
      "Metadata": {
        "type": "object",
        "required": [
          "reportVersion",
          "searchUser",
          "dateRange",
          "repositoriesAnalyzed",
          "generatedAt",
          "enabledModules"
        ],
        "properties": {
          "reportVersion": {
            "type": "string",
            "example": "1.0"
          },
          "searchUser": {
            "type": "string",
            "example": "octocat"
          },
          "dateRange": {
            "$ref": "#/components/schemas/DateRange"
          },
          "repositoriesAnalyzed": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": ["octocat/Hello-World", "github/docs"]
          },
          "generatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-15T10:30:00Z"
          },
          "enabledModules": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "prThroughput",
              "codeChurn",
              "workPatterns",
              "prCycleTime"
            ]
          },
          "criteria": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of criteria used to filter and analyze data"
          },
          "formula": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of formulas used for calculations"
          }
        }
      },
      "DateRange": {
        "type": "object",
        "required": ["start", "end"],
        "properties": {
          "start": {
            "type": "string",
            "format": "date",
            "example": "2024-01-01"
          },
          "end": {
            "type": "string",
            "format": "date",
            "example": "2024-01-31"
          }
        }
      },
      "Summary": {
        "type": "object",
        "required": ["totalContributions", "totalCommits", "totalPRsCreated"],
        "properties": {
          "totalContributions": {
            "type": "integer",
            "description": "Total number of contributions (commits + PRs)",
            "example": 125
          },
          "totalCommits": {
            "type": "integer",
            "description": "Total number of commits",
            "example": 100
          },
          "totalPRsCreated": {
            "type": "integer",
            "description": "Total number of pull requests created",
            "example": 25
          },
          "totalReviewsSubmitted": {
            "type": "integer",
            "description": "Total number of code reviews submitted",
            "example": 50
          },
          "totalComments": {
            "type": "integer",
            "description": "Total number of comments made",
            "example": 200
          },
          "linesAdded": {
            "type": "integer",
            "description": "Total lines of code added",
            "example": 5000
          },
          "linesDeleted": {
            "type": "integer",
            "description": "Total lines of code deleted",
            "example": 2000
          },
          "primaryLanguages": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Primary programming languages used",
            "example": ["JavaScript", "Python", "TypeScript"]
          }
        }
      },
      "Analytics": {
        "type": "object",
        "properties": {
          "prThroughput": {
            "$ref": "#/components/schemas/PRThroughputAnalysis"
          },
          "codeChurn": {
            "$ref": "#/components/schemas/CodeChurnAnalysis"
          },
          "workPatterns": {
            "$ref": "#/components/schemas/WorkPatternsAnalysis"
          },
          "prCycleTime": {
            "$ref": "#/components/schemas/PRCycleTimeAnalysis"
          }
        }
      },
      "PRThroughputAnalysis": {
        "type": "object",
        "required": [
          "totalPRs",
          "statusBreakdown",
          "mergeRate",
          "avgTimeToMerge"
        ],
        "properties": {
          "totalPRs": {
            "type": "integer",
            "example": 25
          },
          "statusBreakdown": {
            "$ref": "#/components/schemas/PRStatusBreakdown"
          },
          "mergeRate": {
            "type": "number",
            "format": "float",
            "description": "Percentage of PRs that were merged",
            "example": 88.5
          },
          "avgTimeToMerge": {
            "type": "string",
            "description": "Average time from PR creation to merge",
            "example": "2.5 days"
          },
          "details": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PRDetail"
            }
          }
        }
      },
      "PRStatusBreakdown": {
        "type": "object",
        "required": ["merged", "closed", "open"],
        "properties": {
          "merged": {
            "type": "integer",
            "example": 20
          },
          "closed": {
            "type": "integer",
            "example": 3
          },
          "open": {
            "type": "integer",
            "example": 2
          }
        }
      },
      "PRDetail": {
        "type": "object",
        "required": ["number", "title", "repository", "state", "created_at"],
        "properties": {
          "number": {
            "type": "integer",
            "example": 123
          },
          "title": {
            "type": "string",
            "example": "Fix authentication bug"
          },
          "repository": {
            "type": "string",
            "example": "octocat/Hello-World"
          },
          "state": {
            "type": "string",
            "enum": ["open", "closed"],
            "example": "closed"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T10:00:00Z"
          },
          "merged_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": "2024-01-03T14:30:00Z"
          },
          "closed_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": "2024-01-03T14:30:00Z"
          },
          "additions": {
            "type": "integer",
            "example": 150
          },
          "deletions": {
            "type": "integer",
            "example": 75
          },
          "changed_files": {
            "type": "integer",
            "example": 5
          }
        }
      },
      "CodeChurnAnalysis": {
        "type": "object",
        "required": [
          "totalCommits",
          "totalAdditions",
          "totalDeletions",
          "netChange",
          "commitSizeDistribution"
        ],
        "properties": {
          "totalCommits": {
            "type": "integer",
            "example": 100
          },
          "totalAdditions": {
            "type": "integer",
            "example": 5000
          },
          "totalDeletions": {
            "type": "integer",
            "example": 2000
          },
          "netChange": {
            "type": "integer",
            "description": "Total additions minus total deletions",
            "example": 3000
          },
          "commitSizeDistribution": {
            "$ref": "#/components/schemas/CommitSizeDistribution"
          },
          "details": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CommitDetail"
            }
          }
        }
      },
      "CommitSizeDistribution": {
        "type": "object",
        "required": ["small", "medium", "large"],
        "properties": {
          "small": {
            "type": "integer",
            "description": "Number of small commits (≤50 lines changed)",
            "example": 60
          },
          "medium": {
            "type": "integer",
            "description": "Number of medium commits (51-500 lines changed)",
            "example": 35
          },
          "large": {
            "type": "integer",
            "description": "Number of large commits (>500 lines changed)",
            "example": 5
          }
        }
      },
      "CommitDetail": {
        "type": "object",
        "required": ["sha", "message", "author", "repository", "stats"],
        "properties": {
          "sha": {
            "type": "string",
            "example": "abc123def456"
          },
          "message": {
            "type": "string",
            "example": "Fix authentication bug"
          },
          "author": {
            "$ref": "#/components/schemas/CommitAuthor"
          },
          "repository": {
            "type": "string",
            "example": "octocat/Hello-World"
          },
          "stats": {
            "$ref": "#/components/schemas/CommitStats"
          }
        }
      },
      "CommitAuthor": {
        "type": "object",
        "required": ["name", "email", "date"],
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "john@example.com"
          },
          "date": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T10:00:00Z"
          }
        }
      },
      "CommitStats": {
        "type": "object",
        "required": ["additions", "deletions", "total"],
        "properties": {
          "additions": {
            "type": "integer",
            "example": 50
          },
          "deletions": {
            "type": "integer",
            "example": 25
          },
          "total": {
            "type": "integer",
            "example": 75
          }
        }
      },
      "WorkPatternsAnalysis": {
        "type": "object",
        "required": [
          "mostActiveDay",
          "afterHoursPercentage",
          "totalActivities",
          "afterHoursCount"
        ],
        "properties": {
          "mostActiveDay": {
            "type": "string",
            "example": "Tuesday"
          },
          "afterHoursPercentage": {
            "type": "number",
            "format": "float",
            "description": "Percentage of activities outside business hours (9 AM - 5 PM)",
            "example": 25.5
          },
          "commitPunchcard": {
            "type": "object",
            "description": "Activity distribution by day and hour",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": {
                "type": "integer"
              }
            }
          },
          "dayDistribution": {
            "type": "object",
            "description": "Activity count by day of week",
            "additionalProperties": {
              "type": "integer"
            },
            "example": {
              "Monday": 15,
              "Tuesday": 20,
              "Wednesday": 18
            }
          },
          "hourDistribution": {
            "type": "object",
            "description": "Activity count by hour of day",
            "additionalProperties": {
              "type": "integer"
            },
            "example": {
              "9": 5,
              "10": 8,
              "11": 12
            }
          },
          "totalActivities": {
            "type": "integer",
            "example": 125
          },
          "afterHoursCount": {
            "type": "integer",
            "example": 32
          }
        }
      },
      "PRCycleTimeAnalysis": {
        "type": "object",
        "required": ["avgCycleTime", "totalPRs", "mergedPRs"],
        "properties": {
          "avgCycleTime": {
            "type": "number",
            "format": "float",
            "description": "Average cycle time in days",
            "example": 2.5
          },
          "totalPRs": {
            "type": "integer",
            "example": 25
          },
          "mergedPRs": {
            "type": "integer",
            "example": 20
          },
          "details": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PRCycleTimeDetail"
            }
          }
        }
      },
      "PRCycleTimeDetail": {
        "type": "object",
        "required": ["number", "title", "repository", "created_at", "status"],
        "properties": {
          "number": {
            "type": "integer",
            "example": 123
          },
          "title": {
            "type": "string",
            "example": "Fix authentication bug"
          },
          "repository": {
            "type": "string",
            "example": "octocat/Hello-World"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-01T10:00:00Z"
          },
          "merged_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": "2024-01-03T14:30:00Z"
          },
          "closed_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": "2024-01-03T14:30:00Z"
          },
          "cycleTime": {
            "type": "number",
            "format": "float",
            "nullable": true,
            "description": "Cycle time in days",
            "example": 2.5
          },
          "status": {
            "type": "string",
            "enum": ["merged", "closed", "open"],
            "example": "merged"
          }
        }
      },
      "RawData": {
        "type": "object",
        "description": "Raw data included when debug mode is enabled",
        "properties": {
          "pullRequests": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Raw pull request data from GitHub API"
          },
          "commits": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Raw commit data from GitHub API"
          },
          "repositories": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of repository names analyzed"
          }
        }
      }
    }
  }
}
